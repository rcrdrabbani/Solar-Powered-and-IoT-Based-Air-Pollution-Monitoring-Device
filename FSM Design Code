        formatTime(timeStr, remaining);

        printCenter(lcd02, 1, "Calibrating...");
        printCenter(lcd02, 2, timeStr);
        //03
        char lineMQ135[21];
        snprintf(lineMQ135, sizeof(lineMQ135), "MQ135 Samp: %d", calCountMQ135);

        printCenter(lcd03, 0, "MQ135");
        printCenter(lcd03, 1, lineMQ135);
        break;
