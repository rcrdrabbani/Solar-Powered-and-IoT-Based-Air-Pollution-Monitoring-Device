  if (!getLocalTime(&timeinfo)) {
    strcpy(buffer, "00:00");
    return;
  }
  strftime(buffer, 6, "%H:%M", &timeinfo);
}

int readMQ7ADC() {
  long sum = 0;
  for (int i = 0; i < ADC_SAMPLE_COUNT; i++) {
    sum += analogRead(MQ7_PIN);
    delayMicroseconds(500);
  }
  return sum / ADC_SAMPLE_COUNT;
}

int readMQ135ADC() {
  long sum = 0;
  for (int i = 0; i < ADC_SAMPLE_COUNT; i++) {
    sum += analogRead(MQ135_PIN);
    delayMicroseconds(500);
  }
  return sum / ADC_SAMPLE_COUNT;
}

int readPM10ADC() {
  digitalWrite(PM10_LED_PIN, LOW);
  delayMicroseconds(280);

  int adcValue = analogRead(PM10_ADC_PIN);

  delayMicroseconds(40);
  digitalWrite(PM10_LED_PIN, HIGH);

  delayMicroseconds(9680);

  return adcValue;
}

float readVoltageAccurate(int pin) {
  int raw = analogRead(pin);
  uint32_t voltage_mv = esp_adc_cal_raw_to_voltage(raw, &adc_chars);
  return voltage_mv / 1000.0;  // konversi mV ke Volt
}

float readDustUGM3_fromADC(int adc) {
  static float buffer[SAMPLE_COUNT];
  static int index = 0;
  static bool filled = false;

  float voltage = adc * (3.3 / 4095.0);
  float Voffset = 0.42;

  float dust_mg = (voltage - Voffset) / 0.5;
  if (dust_mg < 0) dust_mg = 0;

  float dust_ug = dust_mg * 1000.0;

  buffer[index] = dust_ug;
  index++;

  if (index >= SAMPLE_COUNT) {
    index = 0;
    filled = true;
  }

  float sum = 0;
  int count = filled ? SAMPLE_COUNT : index;

  for (int i = 0; i < count; i++) sum += buffer[i];

  return sum / count;
}

