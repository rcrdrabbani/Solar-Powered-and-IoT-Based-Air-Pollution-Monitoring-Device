    Client.publish(MQTT_TOPIC_LOG, msg);
  }
}

bool connectMQTT() {
  mqttLog("MQTT connecting...");

  if (Client.connect(mqtt_client_id, mqtt_user, mqtt_pass)) {
    mqttLog("MQTT connected!");
    Client.subscribe(MQTT_TOPIC_SUB);
    mqttLog("Subscribe esp32/control OK");
    return true;
  } else {
    char m[50];
    snprintf(m, sizeof(m), "MQTT failed, rc=%d", Client.state()); // ✅
    mqttLog(m);
    return false;
  }
}

char TimeMQTT[21];
void getTimeMQTT(char* buffer) {
  struct tm timeinfo;
  if (!getLocalTime(&timeinfo)) {
    strcpy(buffer, "0000-00-00 00:00:00");
    return;
  }
  strftime(buffer, 20, "%Y-%m-%d %H:%M:%S", &timeinfo);
}

void publishMQTT() {

  if (mqttState != MQTT_STATECONNECTED) return;

  char payload[300];
  char timeStr[21];

  getTimeMQTT(timeStr);

  snprintf(payload, sizeof(payload),
           "{"
           "\"device\":\"ESP32MonPol01\","
           "\"time\":\"%s\","
           "\"co\":%.2f,"
           "\"gas\":%.2f,"
           "\"pm10\":%.2f,"
           "\"wifi\":%d,"
           "\"mqtt\":%d"
           "}",
           timeStr,
           mq7avg,
           mq135avg,
           gp2yavg,
           wifiState,
           mqttState);

  Client.publish(MQTT_TOPIC_PUB, payload);
}

void printCenter(LiquidCrystal_I2C& lcd, int row, const char* text) {
  char line[21];
  int len = strlen(text);
  int col = (20 - len) / 2;
  if (col < 0) col = 0;

  memset(line, ' ', 20);
  line[20] = '\0';

  int copyLen = (len > 20) ? 20 : len;
  memcpy(&line[col], text, copyLen);

  lcd.setCursor(0, row);
  lcd.print(line);
}

void formatTime(char* buffer, unsigned long ms) {
  unsigned long totalSec = ms / 1000;
  int minutes = totalSec / 60;
  int seconds = totalSec % 60;

  sprintf(buffer, "%02d:%02d", minutes, seconds);
}

char TimeLCD[6];
void getTimeLCD(char* buffer) {
