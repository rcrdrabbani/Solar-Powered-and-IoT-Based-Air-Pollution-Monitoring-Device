float readMQ7PPM_fromVolt(float Vout) {
  if (Vout <= 0.01) return 0;
  float Vc = 5.0;
  float Rs = (Vc - Vout) / Vout * RL_MQ7;
  if (RO_MQ7 <= 0) return 0;
  float ratio = Rs / RO_MQ7;
  if (ratio <= 0) return 0;
  return pow(10, (log10(ratio) - 1.7) / -0.77);
}

float readMQ135PPM_fromVolt(float Vout) {
  if (Vout < 0.05) Vout = 0.05;
  float Vc = 5.0;
  float Rs = (Vc - Vout) / Vout * RL_MQ135;
  if (RO_MQ135 <= 0) return 0;
  float ratio = Rs / RO_MQ135;
  if (ratio <= 0) return 0;
  return pow(10, (log10(ratio) - 1.5) / -0.38);
}

void mqttCallback(char* topic, byte* payload, unsigned int length) {
  char msg[150];
  if (length >= sizeof(msg)) return;
  memcpy(msg, payload, length);
  msg[length] = '\0';

  char logBuf[150];
  snprintf(logBuf, sizeof(logBuf), "Pesan masuk [%s]: %s", topic, msg);
  mqttLog(logBuf);

  char cmd[20];
  char arg[20];

  int parsed = sscanf(msg, "%19s %19s", cmd, arg);

  if (parsed < 1) return;

  if (strcmp(cmd, "ro7") == 0) {
    if (parsed < 2) {
      char m[60];
      snprintf(m, sizeof(m), "RO_MQ7 saat ini: %.4f", RO_MQ7);
      mqttLog(m);
      return;
    }

    float val = atof(arg);
    if (val > 0 && val < 1000) {
      RO_MQ7 = val;
      char m[60];
      snprintf(m, sizeof(m), "RO_MQ7 diubah ke: %.4f", RO_MQ7);
      mqttLog(m);
    } else {
      mqttLog("ro7: nilai tidak valid (harus 0-1000)");
    }

  } else if (strcmp(cmd, "ro135") == 0) {
    if (parsed < 2) {
      char m[60];
      snprintf(m, sizeof(m), "RO_MQ135 saat ini: %.4f", RO_MQ135);
      mqttLog(m);
      return;
    }
    float val = atof(arg);
    if (val > 0 && val < 1000) {
      RO_MQ135 = val;
      char m[60];
      snprintf(m, sizeof(m), "RO_MQ135 diubah ke: %.4f", RO_MQ135);
      mqttLog(m);
    } else {
      mqttLog("ro135: nilai tidak valid (harus 0-1000)");
    }

  } else if (strcmp(cmd, "skip") == 0) {
    if (parsed < 2) {
      mqttLog("skip: butuh argumen (warmup / calibrating)");
      return;
    }
    if (strcmp(arg, "warmup") == 0) {
      if (systemState == SYSTEM_WARMUP) {
        systemState = SYSTEM_CALIBRATING;
        mqttLog("Skip warmup! Lanjut ke kalibrasi.");
      } else {
        mqttLog("Skip warmup diabaikan, bukan di state warmup.");
      }
    } else if (strcmp(arg, "calibrating") == 0) {
      if (systemState == SYSTEM_CALIBRATING) {
        systemState = SYSTEM_RUNNING;
        mqttLog("Skip kalibrasi! Lanjut ke sampling.");
      } else {
        mqttLog("Skip kalibrasi diabaikan, bukan di state kalibrasi.");
      }
    } else {
      mqttLog("skip: argumen tidak dikenal (warmup / calibrating)");
    }

  } else if (strcmp(cmd, "status") == 0) {
    char m[100];
    snprintf(m, sizeof(m),
             "RO_MQ7:%.4f | RO_MQ135:%.4f | State:%d",
             RO_MQ7, RO_MQ135, systemState);
    mqttLog(m);

  } else if (strcmp(cmd, "reset") == 0) {
    mqttLog("Reset ESP32 dalam 2 detik...");
    Client.loop();
    delay(2000);
    ESP.restart();

  } else {
    char m[60];
    snprintf(m, sizeof(m), "Perintah tidak dikenal: %s", cmd);
    mqttLog(m);
  }
}

void handleWiFi() {
  wl_status_t status = WiFi.status();

  switch (wifiState) {

    case WIFI_CONNECTED:
      if (status != WL_CONNECTED) {
        mqttLog("WiFi lost connection");
        wifiState = WIFI_DISCONNECTED;
      }
      break;

    case WIFI_DISCONNECTED:
      if (millis() - lastWiFiAttempt >= wifiInterval) {
        lastWiFiAttempt = millis();
        mqttLog("WiFi start connecting...");
        WiFi.begin(wifi_ssid, wifi_password);
        wifiState = WIFI_CONNECTING;
      }
      break;

    case WIFI_CONNECTING:
      if (status == WL_CONNECTED) {
        mqttLog("WiFi connected!");
        wifiState = WIFI_CONNECTED;
      } else if (millis() - lastWiFiAttempt >= wifiInterval) {
        mqttLog("WiFi retry...");
        WiFi.begin(wifi_ssid, wifi_password);
        lastWiFiAttempt = millis();
      }
      break;
  }
}

void handleMQTT() {
  if (wifiState != WIFI_CONNECTED) {
    mqttState = MQTT_STATEDISCONNECTED;
    return;
  }

  switch (mqttState) {

    case MQTT_STATECONNECTED:
      if (!Client.connected()) {
        mqttLog("MQTT lost connection");
        mqttState = MQTT_STATEDISCONNECTED;
      } else {
        Client.loop();
      }
      break;

    case MQTT_STATEDISCONNECTED:
      if (millis() - lastMQTTAttempt >= mqttInterval) {
        lastMQTTAttempt = millis();
        if (connectMQTT()) {
          mqttState = MQTT_STATECONNECTED;
        } else {
          mqttState = MQTT_STATECONNECTING;
        }
      }
      break;

    case MQTT_STATECONNECTING:
      if (Client.connected()) {
        mqttLog("MQTT connected!");
        mqttState = MQTT_STATECONNECTED;
      } else if (millis() - lastMQTTAttempt >= mqttInterval) {
        mqttLog("MQTT retry...");
        lastMQTTAttempt = millis();
        if (connectMQTT()) {
          mqttState = MQTT_STATECONNECTED;
        }
      }
      break;
  }
}

void handleSystem() {

  if (systemState != lastState) {

    switch (systemState) {

      case SYSTEM_WARMUP:
        sensorState = SENSOR_IDLE;
        lcdState = LCD_WARMUP;
        warmupStartTime = millis();
        break;

      case SYSTEM_CALIBRATING:
        sensorState = SENSOR_CALIBRATING;
        lcdState = LCD_CALIBRATING;
        calibrateStartTime = millis();
        calSample = millis();
        sumRSMQ7 = 0;
        sumRSMQ135 = 0;
        calCountMQ7 = 0;
        calCountMQ135 = 0;
        break;

      case SYSTEM_RUNNING:
        sensorState = SENSOR_SAMPLING;
        lcdState = LCD_SAMPLING;
        samplingStartTime = millis();
        sumMQ7 = 0;
        sumMQ135 = 0;
        sumGP2Y = 0;
        sample = 0;
        break;
    }
    lastState = systemState;
  }
  switch (systemState) {

    case SYSTEM_WARMUP:
      if (millis() - warmupStartTime >= warmupDuration) {
        systemState = SYSTEM_CALIBRATING;
      }
      break;

    case SYSTEM_CALIBRATING:
      if (millis() - calibrateStartTime >= calibrateDuration) {
        RO_MQ7 = 2.9;
        RO_MQ135 = 10.0;
        systemState = SYSTEM_RUNNING;
      }
      break;
  }
}

void handleSensor() {
  if (millis() - lastSensorRead < sensorInterval) return;
  lastSensorRead = millis();

  switch (sensorState) {
    case SENSOR_IDLE:
      break;

    case SENSOR_CALIBRATING:
      {
        if (millis() - calSample >= sampleInterval) {
          calSample = millis();

          int adcMQ7 = readMQ7ADC();
          int adcMQ135 = readMQ135ADC();

          uint32_t mv7 = esp_adc_cal_raw_to_voltage(adcMQ7, &adc_chars);
          uint32_t mv135 = esp_adc_cal_raw_to_voltage(adcMQ135, &adc_chars);
          float Vout7 = mv7 / 1000.0;
          float Vout135 = mv135 / 1000.0;

          // Guard hanya untuk MQ7
          if (Vout7 <= 0.01) {
            mqttLog("Sample dibuang! MQ7 Vout terlalu kecil.");
            break;
          }

          float Rs7 = (5.0 - Vout7) / Vout7 * RL_MQ7;
          if (Rs7 <= 0 || isinf(Rs7)) {
            mqttLog("Sample dibuang! Rs7 tidak valid.");
            break;
          }

          // MQ135 pakai Vout minimum 0.05 agar tidak div/0
          float Vout135safe = (Vout135 < 0.05) ? 0.05 : Vout135;
          float Rs135 = (5.0 - Vout135safe) / Vout135safe * RL_MQ135;

          sumRSMQ7 += Rs7;
          sumRSMQ135 += Rs135;

          calCountMQ7++;
          calCountMQ135++;
        }
        break;
      }

    case SENSOR_SAMPLING:
      {
        int adcMQ7 = readMQ7ADC();
        uint32_t mv7 = esp_adc_cal_raw_to_voltage(adcMQ7, &adc_chars);
        mq7.adc = adcMQ7;
        mq7.volt = mv7 / 1000.0;
        mq7.value = readMQ7Smooth(readMQ7PPM_fromVolt(mq7.volt));

        int adcMQ135 = readMQ135ADC();
        uint32_t mv135 = esp_adc_cal_raw_to_voltage(adcMQ135, &adc_chars);
        mq135.adc = adcMQ135;
        mq135.volt = mv135 / 1000.0;
        mq135.value = readMQ135Smooth(readMQ135PPM_fromVolt(mq135.volt));


        gp2y.adc = readPM10ADC();
        uint32_t mvGP2Y = esp_adc_cal_raw_to_voltage(gp2y.adc, &adc_chars);
        gp2y.volt = mvGP2Y / 1000.0;
        gp2y.value = readDustUGM3_fromADC(gp2y.adc);

        sumMQ7 += mq7.value;
        sumMQ135 += mq135.value;
        sumGP2Y += gp2y.value;
        sample++;

        if (millis() - samplingStartTime >= samplingDuration && sample > 0) {
          mq7avg = sumMQ7 / sample;
          mq135avg = sumMQ135 / sample;
          gp2yavg = sumGP2Y / sample;

          publishMQTT();

          sumMQ7 = 0;
          sumMQ135 = 0;
          sumGP2Y = 0;
          sample = 0;
          samplingStartTime = millis();
        }
        break;
      }
  }
}

void handleLCD() {
