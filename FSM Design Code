        // ===== LCD 1 =====
        snprintf(line1, sizeof(line1), "CO");
        printCenter(lcd01, 0, line1);

        snprintf(line1, sizeof(line1), "%.1f PPM", mq7avg);
        printCenter(lcd01, 1, line1);

        snprintf(line1, sizeof(line1), "ADC:%d | V:%.2f", mq7.adc, mq7.volt);
        printCenter(lcd01, 2, line1);

        snprintf(line1, sizeof(line1), "WiFi:%d MQTT:%d", wifiState, mqttState);
        printCenter(lcd01, 3, line1);

        // ===== LCD 2 =====
        snprintf(line2, sizeof(line2), "Gas Polutan");
        printCenter(lcd02, 0, line2);

        snprintf(line2, sizeof(line2), "%.1f PPM", mq135avg);
        printCenter(lcd02, 1, line2);

        snprintf(line2, sizeof(line2), "ADC:%d | V:%.2f", mq135.adc, mq135.volt);
        printCenter(lcd02, 2, line2);

        snprintf(line2, sizeof(line2), "MQ7:%.2f MQ135:%.2f", RO_MQ7, RO_MQ135);
        printCenter(lcd02, 3, line2);

        // ===== LCD 3 =====
        snprintf(line3, sizeof(line3), "PM10");
        printCenter(lcd03, 0, line3);

        snprintf(line3, sizeof(line3), "%.1f ug/m3", gp2yavg);
        printCenter(lcd03, 1, line3);

        snprintf(line3, sizeof(line3), "ADC:%d | V:%.2f", gp2y.adc, gp2y.volt);
        printCenter(lcd03, 2, line3);

        getTimeLCD(timeStr);
        printCenter(lcd03, 3, timeStr);

        break;
      }
  }
}

void setup() {
  Serial.begin(115200);

  // ===================== PIN MODE ===================== //
  pinMode(PM10_LED_PIN, OUTPUT);
  digitalWrite(PM10_LED_PIN, HIGH);

  pinMode(MQ7_PIN, INPUT);
  pinMode(MQ135_PIN, INPUT);
  pinMode(PM10_ADC_PIN, INPUT);

  analogReadResolution(12);
  analogSetPinAttenuation(PM10_ADC_PIN, ADC_11db);
  analogSetPinAttenuation(MQ7_PIN, ADC_11db);
  analogSetPinAttenuation(MQ135_PIN, ADC_11db);

  esp_adc_cal_characterize(
    ADC_UNIT_1,
    ADC_ATTEN_DB_11,
    ADC_WIDTH_BIT_12,
    1100,
    &adc_chars);

  // ===================== LCD INIT ===================== //
  Wire.begin(21, 22);
  lcd01.init();
  lcd01.backlight();

  lcd02.init();
  lcd02.backlight();

  lcd03.init();
  lcd03.backlight();

  // ===================== WIFI SETUP ===================== //
  WiFi.mode(WIFI_STA);
  wifiState = WIFI_CONNECTING;
  WiFi.begin(wifi_ssid, wifi_password);
  lastWiFiAttempt = millis();

  // ===================== MQTT SETUP ===================== //
  net.setInsecure();
  Client.setServer(mqtt_server, mqtt_port);
  Client.setCallback(mqttCallback);
  Client.setKeepAlive(60);
  Client.setBufferSize(512);
  // ===================== TIME (NTP) ===================== //
  configTime(7 * 3600, 0, "pool.ntp.org");

  warmupStartTime = millis();
}

void loop() {
  handleSystem();
  handleWiFi();
  handleMQTT();
  handleSensor();
  handleLCD();
}
